# Neon — copy connection string from https://console.neon.tech
# You can put this in `apps/api/.env` or in the repo root `.env` (both are loaded).
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Required in production — use a long random string (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-in-production

PORT=4000
# Browser origins allowed to call the API with credentials (comma-separated). Match your deployed site, e.g. https://yoursite.netlify.app
CORS_ORIGIN=http://localhost:3000
